{
  "name": "solid-fa",
  "version": "0.2.0",
  "description": "Tiny FontAwesome component for SolidJS",
  "keywords": [
    "component",
    "icon",
    "svg",
    "duotone",
    "fontawesome",
    "font-awesome",
    "solid",
    "solidjs",
    "solid-js",
    "solid.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cweili/solid-fa.git"
  },
  "author": "Cweili",
  "license": "MIT",
  "type": "module",
  "homepage": "https://cweili.github.io/solid-fa/",
  "bugs": {
    "url": "https://github.com/Cweili/solid-fa/issues"
  },
  "jsdelivr": "dist/solid-fa.js",
  "unpkg": "dist/solid-fa.js",
  "module": "dist/solid-fa.esm.js",
  "main": "dist/solid-fa.cjs.js",
  "source": "src/index.ts",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "solid": "./dist/solid-fa.esm.js",
      "import": "./dist/solid-fa.esm.js",
      "require": "./dist/solid-fa.cjs.js",
      "default": "./dist/solid-fa.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:docs": "vite build --config docs/vite.config.ts",
    "dev": "vite --config docs/vite.config.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "lint": "eslint --fix \"{src,test,docs}/*.{js,ts,tsx}\"",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@cweili/fa-test-util": "^1.0.0",
    "@fortawesome/fontawesome-common-types": "6.5.2",
    "@fortawesome/free-solid-svg-icons": "6.4.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "postcss": "8.5",
    "solid-js": "^1.9.13",
    "typescript": "5.8",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "solid-js": "^1.0.0",
    "@fortawesome/fontawesome-common-types": "*"
  }
}
